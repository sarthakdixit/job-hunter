# Copy this file to `.env` and fill in your keys.

# Which LLM powers resume analysis + job matching: anthropic | gemini
RJF_PROVIDER=anthropic

# Anthropic (Claude) API key — required when RJF_PROVIDER=anthropic.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — required when RJF_PROVIDER=gemini.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Tavily API key — powers the scoped web search (used by BOTH providers).
# Get one at https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# Optional overrides
RJF_MODEL=claude-opus-4-8        # Claude model (anthropic provider)
RJF_GEMINI_MODEL=gemini-2.5-pro  # Gemini model (gemini provider)
RJF_EFFORT=high                  # Anthropic reasoning effort: low | medium | high | max
